# Kopioi tiedostoksi ~/.elukkavex.env ja täytä arvot

# Telegram (sama token kuin bot.py:ssä)
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
CHAT_IDS=123456789

# ESP32:n autentikointi (keksi satunnainen merkkijono, sama kuin config.h:ssa)
UPLOAD_TOKEN=vaihda_tama_salaiseksi

# Vapaaehtoinen: kuvakansio (oletus: ~/elukkavex/images)
# IMAGE_DIR=/home/pi/elukkavex/images

# Vapaaehtoinen: portti (oletus: 8080)
# PORT=8080
